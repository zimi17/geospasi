# Supabase / PostGIS Connection
# Copy file ini ke .env dan isi credentials dari Supabase dashboard

SUPABASE_URL=https://[YOUR-REF].supabase.co
SUPABASE_DB_URL=postgresql://[YOUR-USER]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIs...

# Untuk koneksi lokal (opsional, fase 2+)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=spasi_db
# DB_USER=postgres
# DB_PASSWORD=
